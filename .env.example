# =====================================================
# OmniBot AI 環境變數設定檔
# =====================================================
# 請複製此檔案為 .env 並填入實際值
# 重要：請勿將包含真實密鑰的 .env 檔案提交至版本控制系統
# =====================================================

# ------------------------------------------------------------
# 資料庫設定
# ------------------------------------------------------------
DB_USER=omnibot
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_NAME=omnibot
DB_HOST=postgres
DB_PORT=5432

# ------------------------------------------------------------
# JWT 認證設定
# ------------------------------------------------------------
# 重要：生產環境必須變更為強隨機密鑰 (建議至少 256 位元)
JWT_SECRET=CHANGE_TO_STRONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=7d

# ------------------------------------------------------------
# 節點環境
# ------------------------------------------------------------
NODE_ENV=production
PORT=3000

# ------------------------------------------------------------
# AI 服務提供者
# ------------------------------------------------------------
# 請至以下網站取得 API Key:
# OpenAI: https://platform.openai.com/api-keys
# Anthropic: https://console.anthropic.com/
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY_HERE

# ------------------------------------------------------------
# AI 模型設定
# ------------------------------------------------------------
DEFAULT_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# ------------------------------------------------------------
# 向量資料庫 (Qdrant)
# ------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=YOUR_QDRANT_API_KEY

# ------------------------------------------------------------
# LINE 訊息服務
# ------------------------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN
LINE_CHANNEL_SECRET=YOUR_LINE_CHANNEL_SECRET

# ------------------------------------------------------------
# Facebook Messenger
# ------------------------------------------------------------
FACEBOOK_PAGE_ACCESS_TOKEN=YOUR_FACEBOOK_PAGE_ACCESS_TOKEN
FACEBOOK_PAGE_ID=YOUR_FACEBOOK_PAGE_ID

# ------------------------------------------------------------
# RabbitMQ 訊息佇列
# ------------------------------------------------------------
RABBITMQ_USER=omnibot
RABBITMQ_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ------------------------------------------------------------
# 前端 URLs
# ------------------------------------------------------------
VITE_API_URL=http://omnichat.ordoai.co/api
VITE_WS_URL=ws://omnichat.ordoai.co/api
VITE_WIDGET_ID=default

# ------------------------------------------------------------
# CORS 設定
# ------------------------------------------------------------
# 允許的來源網域，用逗號分隔
# 生產環境應指定明確的網域，不要使用 *
# 例如: https://admin.yourdomain.com,https://yourdomain.com
CORS_ORIGINS=*
